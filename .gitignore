# ===========================================================
#  Secrets & credentials — never commit these
# ===========================================================
.env
.env.*
*.env
.envrc
*_api_key*
*_token*
*secret*
*credential*
credentials.json
secrets.json
*.pem
*.key
service-account*.json
gcp-*.json

# ===========================================================
#  Tooling / local config
# ===========================================================
.claude/

# ===========================================================
#  Hugo build artifacts
# ===========================================================
.hugo_build.lock
/resources/_gen/
hugo_stats.json

# ===========================================================
