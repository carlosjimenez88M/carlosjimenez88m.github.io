# ===========================================================
*.pkl
tidytuesday/data/embeddings_cache.pkl
tidytuesday/data/*.pkl

# ===========================================================
#  Python
# ===========================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.venv/
.venv/
venv/
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ===========================================================
#  Node
# ===========================================================
node_modules/

